# --- Twitch ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USERNAME=

# --- Kick (official public API, OAuth client credentials) ---
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_USERNAME=

# --- Rumble (official Live Stream API URL from rumble.com/account/livestream-api) ---
RUMBLE_API_URL=
RUMBLE_API_KEY=
RUMBLE_CHANNEL=

# --- TikTok (via the Python sidecar service in /tiktok-service) ---
TIKTOK_USERNAME=
TIKTOK_SERVICE_URL=

# --- YouTube ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Verbose per-request YouTube logging (every API call, status code, parsed
# fields, live/offline reasoning, fallback activity). Leave unset/false in
# normal operation.
DEBUG_YOUTUBE=false

# Optional tuning (sensible defaults are used if left unset):
# YOUTUBE_OFFLINE_POLL_MS=300000        # search.list cadence while offline (expensive call)
# YOUTUBE_LIVE_POLL_MS=15000            # videos.list cadence while live (cheap call)
# YOUTUBE_MAX_BACKOFF_MS=1800000        # cap on exponential backoff after official API errors
# YOUTUBE_REQUEST_TIMEOUT_MS=10000      # per-request timeout for the official API
# YOUTUBE_SOURCE_SWITCH_COOLDOWN_MS=120000  # min time to stay on fallback before switching back
# YOUTUBE_RECOVERY_CHECK_MS=60000       # how often to retry the official API while on fallback
# YOUTUBE_STALE_CACHE_MS=180000         # how long to serve cached data if both sources fail


# --- Multi-Platform Chat Widget (public/chat, browser source: /chat) ---
# Twitch and Kick chat need no extra config beyond the values above
# (TWITCH_USERNAME / KICK_USERNAME are reused as the channel to join).

# Kick: only needed if the automatic chatroom-id lookup fails (Cloudflare
# occasionally blocks server-side lookups). Find it manually by opening
# https://kick.com/api/v2/channels/<your-slug> in a browser and copying
# "chatroom":{"id": ...}
KICK_CHATROOM_ID=
# Only needed if Kick rotates its public Pusher app key.
KICK_PUSHER_APP_KEY=

# YouTube chat: deploy /youtube-chat-service (pytchat) as its own Render
# service, then put its public URL here. Reuses YOUTUBE_API_KEY/YOUTUBE_CHANNEL_ID above.
YOUTUBE_CHAT_SERVICE_URL=

# TikTok chat: reuses TIKTOK_SERVICE_URL above - the same sidecar now
# also serves /chat, no separate deploy needed.

# Rumble chat: reuses RUMBLE_API_URL / RUMBLE_CHANNEL above - chat
# messages come from the same official Live Stream API response.

# Instagram: Instagram has no official Live-comments API. This
# integration stays idle unless you point it at a bridge you control
# that returns { "live": bool, "messages": [{ "username", "text" }] }.
# See services/chat/instagramChat.js for details.
INSTAGRAM_USERNAME=
INSTAGRAM_SESSION=
INSTAGRAM_LIVE_COMMENTS_URL=

# --- Server ---
PORT=3000
